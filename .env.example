# Copiar este archivo como .env y completar con valores reales
# NUNCA subir el archivo .env al repositorio

# ── PostgreSQL superusuario (solo para Docker y migrate.sh) ──
POSTGRES_PASSWORD=CAMBIAR_POR_CLAVE_SEGURA_ROOT

# ── Base de datos (conexión de la aplicación) ─────────────────
DB_USER=app_user
DB_HOST=db
DB_NAME=registro_usuarios
DB_PASSWORD=CAMBIAR_POR_CLAVE_APP_USER
DB_PORT=5432
DB_SSL=false

# ── JWT ───────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_SECRETO_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=2h

# ── URLs de la aplicación ─────────────────────────────────────
APP_URL=https://iapixelcode.com
FRONTEND_URL=https://iapixelcode.com
ALLOWED_ORIGINS=https://iapixelcode.com

# ── Correo (nodemailer) ───────────────────────────────────────
MAIL_USER=tucorreo@gmail.com
MAIL_PASS=CONTRASEÑA_DE_APLICACION_GMAIL

# ── Recuperación de contraseña ────────────────────────────────
RECOVERY_TOKEN_MINUTES=60

# ── Monitoreo ─────────────────────────────────────────────────
# Token para proteger GET /monitor/stats  (cabecera x-monitor-token: <valor>)
# Dejar vacío para acceso libre (el puerto está en loopback de todas formas)
MONITOR_TOKEN=

# ── Grafana ───────────────────────────────────────────────────
GRAFANA_PASSWORD=CAMBIAR_POR_CLAVE_GRAFANA

# ── Caddy ─────────────────────────────────────────────────────
# Local:      CADDYFILE=./Caddyfile.local
# Producción: CADDYFILE=./Caddyfile.prod
CADDYFILE=./Caddyfile.local
